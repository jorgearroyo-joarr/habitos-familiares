# ============================================================
# HábitosFam – Environment Configuration Example
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="HábitosFam"
APP_VERSION="2.0.0"
DEBUG=true
SECRET_KEY="change-this-to-a-random-secret-key-in-production"

# ── Admin Panel ───────────────────────────────────────────────
# PIN to access the admin panel (change this!)
ADMIN_PIN="1234"

# ── Database ─────────────────────────────────────────────────
# --- OPTION 1: SQLite (default, local file) ---
DATABASE_URL="sqlite:///./habitosfam.db"

# --- OPTION 2: PostgreSQL / Supabase ---
# DATABASE_URL="postgresql://user:password@host:5432/habitosfam"
# For Supabase, use the connection string from Settings > Database > Connection string

# --- OPTION 3: MySQL ---
# DATABASE_URL="mysql+pymysql://user:password@host:3306/habitosfam"

# ── CORS ──────────────────────────────────────────────────────
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS="http://localhost:8765,http://localhost:3000"

# ── Server ────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8765
